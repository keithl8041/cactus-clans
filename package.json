{
  "name": "cactus-clans",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc -p tsconfig.json && tsc -p worker/tsconfig.json",
    "parse-cards": "node scripts/parse-cards.mjs",
    "worker:dev": "wrangler dev",
    "worker:deploy": "npm run build && wrangler deploy",
    "db:apply": "wrangler d1 execute cactus-clans --remote --file=worker/schema.sql",
    "db:apply:local": "wrangler d1 execute cactus-clans --local --file=worker/schema.sql"
  },
  "dependencies": {
    "headroom-ai": "^0.1.0",
    "phaser": "^3.85.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250501.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.6.3",
    "vite": "^6.4.2",
    "wrangler": "^4.0.0"
  }
}
